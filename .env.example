# BlenderMCPServer — copy to .env and fill in values

# LLM API keys (for LangGraph agents in Phase 2+)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
NVIDIA_API_KEY=

# LLM_PROVIDER: auto | qwen | ollama | gemini | nvidia | gemma | claude
# auto tries Qwen (fast), then Ollama, then Gemini, then NVIDIA, then DeepSeek, then Claude.
LLM_PROVIDER=auto
QWEEN_MODEL=qwen3:4b
OLLAMA_MODEL=gemma4:12b
OLLAMA_BASE_URL=http://172.31.42.118:11434
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:4b
NVIDIA_NIM_MODEL=google/gemma-4-31b-it
NVIDIA_NIM_TIMEOUT_SECONDS=75

# Cloudflare R2 storage
R2_ACCOUNT_ID=e4e93a2fb32f5ec8d4559e62f1f4654a
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=blender-outputs
# Optional: public domain for bucket (leave blank to use presigned URLs)
R2_PUBLIC_URL=

# Shared secret — Rust video_editor and this server must match
MCP_API_KEY=

# Server config
PORT=8000

# Optional: override blender binary path (default: "blender" in PATH)
# BLENDER_BIN=/usr/bin/blender

# Presigned URL expiry in seconds (default: 86400 = 24 hours)
# R2_PRESIGN_EXPIRY=86400
